  "$id": "lancedb-robotics/training-loader-report/v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "if": {
        "properties": {
          "loader": {
            "properties": {
              "kind": {
                "const": "native-training"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "snapshot"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "loader": {
            "properties": {
              "kind": {
                "const": "aligned-training"
              }
            }
          }
        }
      },
      "then": {
        "required": [
          "alignment",
          "read_table_versions"
        ]
      }
    }
